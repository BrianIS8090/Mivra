{
  "name": "mivra",
  "private": true,
  "version": "0.6.8",
  "type": "module",
  "scripts": {
    "dev": "npm run build:plugins && vite",
    "build:plugins": "vite build --config plugins/export-pdf/vite.config.ts && node plugins/export-pdf/scripts/copy-manifest.mjs",
    "build": "npm run build:plugins && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "gen:types": "cargo run --manifest-path src-tauri/Cargo.toml --bin export_bindings",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@milkdown/core": "^7.18.0",
    "@milkdown/crepe": "^7.18.0",
    "@milkdown/ctx": "^7.18.0",
    "@milkdown/react": "^7.18.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "dejavu-fonts-ttf": "^2.37.3",
    "mammoth": "^1.12.0",
    "mermaid": "^11.13.0",
    "pdfjs-dist": "^5.7.284",
    "pdfmake": "^0.3.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/pdfmake": "^0.3.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^28.0.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.18"
  }
}
